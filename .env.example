# Social0 CLI environment variables
# Copy to .env for local development (optional — prefer `social0 login`)

# API key (sk_live_...)
SOCIAL0_API_KEY=

# API base URL (default: https://api.social0.app/v1)
SOCIAL0_API_URL=

# Request timeout in milliseconds (default: 30000)
SOCIAL0_REQUEST_TIMEOUT_MS=

# Max retries on rate limit (default: 3)
SOCIAL0_MAX_RETRIES=
